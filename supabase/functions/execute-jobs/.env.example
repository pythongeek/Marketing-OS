# Supabase Edge Function: execute-jobs
# Environment variables needed for the Edge Function to run.
# Set these in Supabase Dashboard → Edge Functions → execute-jobs → Secrets
#
# IMPORTANT: At least ONE AI provider key is required. The function will
# auto-detect available providers in this priority order:
#   1. MiniMax M3 (primary)
#   2. OpenAI (fallback)
#   3. Kimi (fallback)
#
# To set secrets, use the Supabase CLI:
#   npx supabase secrets set --env-file ./supabase/functions/execute-jobs/.env
#
# Or set individually:
#   npx supabase secrets set MINIMAX_API_KEY=sk-...

# =============================================================================
# Supabase (Required)
# =============================================================================
SUPABASE_URL=https://pusttdxrtmgvhdzdyvbd.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# =============================================================================
# AI Provider Keys (At least ONE required)
# =============================================================================

# --- MiniMax M3 (Primary) ---
# Get your key at: https://www.minimaxi.com/
# The key should start with something like "sk-..." (not "sk-cp-...")
# If you get "invalid api key (2049)", your key may be expired or from a different service.
MINIMAX_API_KEY=<your-minimax-key>
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M3

# --- OpenAI (Fallback #1) ---
# Get your key at: https://platform.openai.com/
OPENAI_API_KEY=<your-openai-key>
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# --- Kimi (Fallback #2) ---
# Get your key at: https://platform.moonshot.cn/
KIMI_API_KEY=<your-kimi-key>
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-latest

# =============================================================================
# LLM Parameters (Optional)
# =============================================================================
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# =============================================================================
# Slack Notifications (Optional)
# =============================================================================
SLACK_WEBHOOK_URL=<your-slack-webhook-url>
