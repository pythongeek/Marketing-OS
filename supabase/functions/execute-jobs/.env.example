# Supabase Edge Function: execute-jobs
# Environment variables needed for the Edge Function to run.
# Set these in Supabase Dashboard → Edge Functions → execute-jobs → Secrets

# Supabase (self-reference - the function needs to call itself via Supabase client)
SUPABASE_URL=https://pusttdxrtmgvhdzdyvbd.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# LLM Provider (choose ONE)
# Option A: OpenAI (recommended)
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o
OPENAI_API_KEY=<your-openai-key>

# Option B: Minimax (alternative)
# DEFAULT_LLM_PROVIDER=minimax
# DEFAULT_LLM_MODEL=MiniMax-M3
# MINIMAX_API_KEY=<your-minimax-key>

# Optional: Slack notifications
SLACK_WEBHOOK_URL=<your-slack-webhook-url>
