# AgenticMarketingPro — Vercel Admin Environment
# Copy this to web/.env.local and fill in your Supabase credentials

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Webhook secret (optional — for external trigger verification)
WEBHOOK_SECRET=your-webhook-secret-here

# Optional: for direct vault access from Vercel (if hosting vault files statically)
# VAULT_PUBLIC_URL=/AgenticMarketingPro-Vault
