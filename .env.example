# AgenticMarketingPro — Environment Configuration
# Copy this to .env and fill in your actual API keys

# =============================================================================
# Supabase (Required for poller)
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# LLM / Embeddings (Critical — at least one required)
# =============================================================================
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# HERMES_AGENT_API_KEY=...
# MINIMAX_API_KEY=...

EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# =============================================================================
# Vector DB (ChromaDB is local, always works if installed)
# =============================================================================
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=amp_vault
# PINECONE_API_KEY=...
# PINECONE_INDEX_NAME=...

# =============================================================================
# SEO Data APIs (Optional — configure as needed)
# =============================================================================
# AHREFS_API_KEY=...
# SEMRUSH_API_KEY=...
# DATAFORSEO_LOGIN=...
# DATAFORSEO_PASSWORD=...
# SERPAPI_KEY=...

# =============================================================================
# Google APIs (Optional — OAuth2 or service account)
# =============================================================================
# GOOGLE_CLIENT_SECRETS_FILE=client_secrets.json
# GA4_PROPERTY_ID=properties/123456789
# GSC_PROPERTY=https://example.com/
# BING_API_KEY=...

# =============================================================================
# Paid Ads APIs (Optional)
# =============================================================================
# GOOGLE_ADS_DEVELOPER_TOKEN=...
# GOOGLE_ADS_CLIENT_ID=...
# GOOGLE_ADS_CLIENT_SECRET=...
# GOOGLE_ADS_REFRESH_TOKEN=...
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=...
# META_ACCESS_TOKEN=...
# LINKEDIN_ADS_TOKEN=...

# =============================================================================
# Social / Outreach / CRM (Optional)
# =============================================================================
# BUFFER_ACCESS_TOKEN=...
# AYRSHARE_API_KEY=...
# HUBSPOT_API_KEY=...
# HUNTER_API_KEY=...
# INSTANTLY_API_KEY=...
# KLAVIYO_API_KEY=...
# NOTION_TOKEN=...
# SLACK_WEBHOOK_URL=...

# =============================================================================
# Content / AI Tools (Optional)
# =============================================================================
# SURFER_API_KEY=...
# CLEARSCOPE_API_KEY=...
# PERPLEXITY_API_KEY=...
# ELEVENLABS_API_KEY=...
# HEYGEN_API_KEY=...
# RUNWAY_API_KEY=...
# MIDJOURNEY_API_KEY=...

# =============================================================================
# Monitoring (Optional)
# =============================================================================
# CLOUDFLARE_API_TOKEN=...
# CLOUDFLARE_ZONE_ID=...
# UPTIME_ROBOT_API_KEY=...
# PAGESPEED_API_KEY=...

# =============================================================================
# GEO / AI Citation Tracking (Optional)
# =============================================================================
# PROFOUND_API_KEY=...
# OTTERLY_API_KEY=...
# BRANDWATCH_API_KEY=...


# =============================================================================
# Bing Webmaster OAuth 2.0 (for Vercel deployment)
# =============================================================================
# Get these from https://portal.azure.com → App Registrations
# See docs/bing-oauth-setup.md for full walkthrough
BING_CLIENT_ID=
BING_CLIENT_SECRET=
BING_TENANT=common
BING_REDIRECT_URI=https://marketing-os-chi-three.vercel.app/api/bing-auth/callback

# =============================================================================
# Paths (Adjust if your vault is in a different location)
# =============================================================================
VAULT_ROOT=./AgenticMarketingPro-Vault
LOG_DIR=./AgenticMarketingPro-Vault/11-Ops/agent-logs
COST_LOG=./AgenticMarketingPro-Vault/11-Ops/agent-logs/cost-tracker.jsonl
HEALTH_LOG=./AgenticMarketingPro-Vault/11-Ops/agent-logs/health-check.jsonl

# =============================================================================
# Rate Limits & Budgets
# =============================================================================
DEFAULT_RATE_LIMIT_RPS=1.0
DEFAULT_MAX_RETRIES=3
DEFAULT_BACKOFF_BASE=2.0

LLM_DAILY_BUDGET_USD=5.0
LLM_MONTHLY_BUDGET_USD=100.0
